{
    "name": "crypto-wallet-manager",
    "version": "1.0.0",
    "scripts": {
        "build": "tsc",
        "start": "ts-node src/index.ts",
        "example": "ts-node src/example.ts",
        "test": "jest --forceExit",
        "test:watch": "jest --watch",
        "lint": "eslint 'src/**/*.ts' '__tests__/**/*.ts'"
    },
    "dependencies": {
        "dotenv": "^10.0.0",
        "ethers": "^5.7.0",
        "sqlite3": "^5.0.0"
    },
    "devDependencies": {
        "@types/jest": "^27.5.2",
        "@types/node": "^16.18.126",
        "eslint": "^7.32.0",
        "jest": "^27.0.0",
        "ts-jest": "^27.1.5",
        "ts-node": "^10.0.0",
        "typescript": "^4.5.0"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": [
            "**/__tests__/**/*.test.ts"
        ],
        "globals": {
            "ts-jest": {
                "tsconfig": "tsconfig.json"
            }
        }
    }
}
