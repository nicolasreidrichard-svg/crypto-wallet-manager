# .env.example

# RPC endpoint configuration for various networks

# Ethereum Mainnet
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Polygon (Matic) Mainnet
POLYGON_RPC_URL=https://polygon-rpc.com/

# Arbitrum One
ARBITRUM_RPC_URL=https://rpc.ankr.com/arbitrum

# Optimism
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# ProfitFunnelTool configuration

# Comma-separated list of GitHub repos to monitor (e.g. owner/arbitrage-bot,owner/nft-gallery)
PROFIT_FUNNEL_REPOS=owner/arbitrage-bot,owner/sandwich-attack-monitor,owner/nft-gallery,owner/dust-consolidator

# How often to check for new profit reports (in milliseconds, default: 3600000 = 1 hour)
PROFIT_FUNNEL_CHECK_INTERVAL_MS=3600000

# Minimum accumulated ETH profit to trigger recording (in ETH)
PROFIT_FUNNEL_ETH_THRESHOLD=0.01

# Minimum accumulated SOL profit to trigger recording (in SOL)
PROFIT_FUNNEL_SOL_THRESHOLD=0.1

# Ethereum wallet address for profit deposits
PROFIT_FUNNEL_ETH_WALLET=0xYOUR_ETHEREUM_WALLET_ADDRESS

# Solana wallet address for profit deposits
PROFIT_FUNNEL_SOL_WALLET=YOUR_SOLANA_WALLET_ADDRESS

# GitHub personal access token (for accessing private repos)
GITHUB_TOKEN=YOUR_GITHUB_TOKEN

# Infura project ID for Ethereum interactions
INFURA_API_KEY=YOUR_INFURA_PROJECT_ID

# Solana RPC URL
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
